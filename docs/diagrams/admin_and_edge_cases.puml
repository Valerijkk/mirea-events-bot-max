== Сценарий: Bulk-импорт из ИС вуза ==

actor "ИС вуза\n(priem.mirea.ru)" as IS
participant "REST API" as API3
database "БД" as DB6

IS -> API3: POST /api/v1/integration/events/sync
IS -> API3: Header: X-API-Key: ***

API3 -> API3: Валидация X-API-Key\n(поиск по key_hash)

loop Для каждого события в payload
  API3 -> DB6: SELECT по (source, external_id)

  alt Событие существует
    API3 -> DB6: UPDATE полей
    API3 -> API3: Идемпотентность сохранена
  else Новое событие
    API3 -> DB6: INSERT событие
    API3 -> DB6: organizer_id = владелец ключа

    alt auto_publish = True
      API3 -> DB6: status = PUBLISHED
    else auto_publish = False
      API3 -> DB6: status = DRAFT
    end
  end
end

API3 -> IS: 200 OK + список созданных/обновлённых ID

@enduml
